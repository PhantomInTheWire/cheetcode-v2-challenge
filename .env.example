# Copy to .env.local and fill with your own values.

# Convex deployment used by Next.js app and API routes
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Shared secret used by server-side actions/mutations
CONVEX_MUTATION_SECRET=replace-with-strong-secret

# GitHub OAuth app credentials for sign-in
AUTH_GITHUB_ID=replace-with-github-oauth-client-id
AUTH_GITHUB_SECRET=replace-with-github-oauth-client-secret

# Auth.js session encryption secret
AUTH_SECRET=replace-with-random-32-byte-secret

# Runtime mode switch used by this app for dev-only features.
# Set to "development" to enable auto-solve/dev routes.
MY_ENV=production

# Optional: Vercel Sandbox auth (required for Level 3 sandbox execution when
# not running on Vercel OIDC). Set all three together.
VERCEL_TOKEN=replace-with-vercel-access-token
VERCEL_TEAM_ID=replace-with-vercel-team-id
VERCEL_PROJECT_ID=replace-with-vercel-project-id
