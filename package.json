    "@uiw/react-codemirror": "^4.25.7",
    "@upstash/redis": "^1.36.3",
    "@vercel/sandbox": "^1.7.1",
    "convex": "^1.32.0",
    "is-ip": "^5.0.1",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "prismjs": "^1.30.0",
    "quickjs-emscripten": "^0.31.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
